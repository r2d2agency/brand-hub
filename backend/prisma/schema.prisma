generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Branding {
  id              String   @id @default("singleton")
  siteName        String   @default("Basmar Doces")
  tagline         String?
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String   @default("#e91e63")
  secondaryColor  String   @default("#9c27b0")
  accentColor     String   @default("#ff4081")
  backgroundColor String   @default("#ffffff")
  foregroundColor String   @default("#0f172a")
  fontHeading     String   @default("Inter")
  fontBody        String   @default("Inter")
  
  // Footer & Social
  footerText      String?  @default("Sua parceira ideal para transformar qualquer comemoração em um momento mágico. Desde o doce até a decoração, estamos com você desde 1991.")
  footerLogo      String?
  instagramUrl    String?
  facebookUrl     String?
  youtubeUrl      String?
  
  // Social Colors
  instagramColor  String   @default("#e1306c")
  facebookColor   String   @default("#1877f2")
  youtubeColor    String   @default("#ff0000")
  
  // WhatsApp Floating
  whatsappPhone   String?  @default("5511999999999")
  whatsappMessage String?  @default("Olá! Gostaria de saber mais sobre os produtos da Basmar.")
  
  // UI Colors
  footerBgColor   String   @default("#0f172a")
  footerTextColor String   @default("#ffffff")
  buttonBgColor   String   @default("#e91e63")
  buttonTextColor String   @default("#ffffff")

  // Section intro texts
  coursesIntro    String?  @default("Aprenda com quem entende do assunto: workshops, oficinas e cursos para todos os níveis.")

  // SEO & Analytics
  seoTitle         String?
  seoDescription   String?
  seoKeywords      String?
  seoOgImage       String?
  seoAuthor        String?
  gtmId            String?
  gaId             String?
  facebookPixelId  String?
  headCode         String?  @db.Text
  bodyCode         String?  @db.Text

  updatedAt       DateTime @updatedAt
}

model Page {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  content        Json     @default("{}")
  published      Boolean  @default(true)
  seoTitle       String?
  seoDescription String?
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Module {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String?
  enabled     Boolean  @default(true)
  showInHome  Boolean  @default(true)
  showInNav   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SeasonalBanner {
  id            String    @id @default(cuid())
  title         String
  subtitle      String?
  imageDesktop  String
  imageMobile   String?
  buttonText    String?
  buttonLink    String?
  startDate     DateTime?
  endDate       DateTime?
  active        Boolean   @default(true)
  isDefault     Boolean   @default(false)
  fontFamily    String?   @default("Inter")
  fontSize      String?   @default("4xl md:text-6xl lg:text-8xl")
  transitionTime Int?      @default(5000)
  transitionType String?   @default("fade")
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProductCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  coverImage  String?
  icon        String?  // lucide name or emoji
  gallery     String[] @default([])
  whatsappMsg String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  showInHome  Boolean  @default(true)
  showInMenu  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Benefit {
  id        String   @id @default(cuid())
  icon      String   // lucide icon name
  title     String
  subtitle  String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inspiration {
  id        String   @id @default(cuid())
  title     String
  image     String
  gallery   String[] @default([])
  link      String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomeBanner {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "courses-promo", "about-store"
  title       String
  subtitle    String?
  description String?  @db.Text
  image       String?
  ctaText     String?
  ctaLink     String?
  bgColor     String?  @default("#1e3a8a")
  textColor   String?  @default("#ffffff")
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PegueMonte {
  id          String   @id @default(cuid())
  name        String
  theme       String?
  slug        String   @unique
  description String?
  items       String[] @default([])
  videoUrl    String?
  coverImage  String?
  gallery     String[] @default([])
  partyType   String?
  peopleCount String?
  unit        String?
  obs         String?
  whatsappMsg String?
  active      Boolean  @default(true)
  highlight   Boolean  @default(false)
  storePhones Json?    @default("[]") @map("store_phones")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("pegue_monte")
}

enum CourseStatus {
  SOON
  OPEN
  CLOSED
}

model Course {
  id                String       @id @default(cuid())
  title             String
  slug              String       @unique
  description       String?
  coverImage        String?      @map("cover_image")
  gallery           String[]     @default([])
  date              DateTime?
  time              String?
  location          String?
  instructor        String?
  registrationStart DateTime?    @map("registration_start")
  registrationEnd   DateTime?    @map("registration_end")
  status            CourseStatus @default(SOON)
  whatsappMsg       String?      @map("whatsapp_msg")
  active            Boolean      @default(true)
  showInHome        Boolean      @default(true) @map("show_in_home")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@map("courses")
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String
  category    String?
  image       String
  description String?
  tags        String[] @default([])
  active      Boolean  @default(true)
  showInHome  Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  logo        String
  description String?
  gallery     String[] @default([])
  active      Boolean  @default(true)
  showInHome  Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Store {
  id           String   @id @default(cuid())
  name         String
  address      String
  city         String?
  state        String?
  zipCode      String?
  neighborhood String?
  phone        String?
  whatsapp     String?
  hours        String?
  mapsLink     String?
  latitude     Float?
  longitude    Float?
  images       String[] @default([])
  active       Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CompanyHistory {
  id          String   @id @default("singleton")
  title       String   @default("Nossa História")
  content     String   @db.Text
  mainImage   String?
  gallery     String[] @default([])
  timeline    Json     @default("[]") // [{year, title, desc, image}]
  updatedAt   DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  text      String   @db.Text
  image     String?
  source    String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhatsAppClick {
  id        String   @id @default(cuid())
  type      String   // category, kit, course, general, promotion
  relatedId String?  // ID of the item clicked
  origin    String?  // page URL
  createdAt DateTime @default(now())
}

model Promotion {
  id          String   @id @default(cuid())
  title       String
  image       String
  price       String?
  oldPrice    String?
  description String?
  whatsappMsg String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsVideo {
  id          String   @id @default(cuid())
  title       String
  youtubeUrl  String
  thumbnail   String
  tags        String[] @default([])
  orientation String   @default("horizontal") // horizontal, vertical
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

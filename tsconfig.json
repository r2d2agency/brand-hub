{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "paths": {
      "@/*": [
        "./frontend/src/*",
        "./src/*"
      ]
    },
    "types": []
  },
  "include": [
    "frontend/src",
    "src",
    "global.d.ts"
  ],
  "exclude": [
    "node_modules",
    "backend",
    "**/dist",
    "**/build"
  ]
}